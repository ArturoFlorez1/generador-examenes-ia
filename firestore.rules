rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Role helpers
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'florezarturo1816@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin')
      );
    }

    function isTeacher() {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'teacher')
      );
    }

    function isEnrolled(courseId) {
      return isSignedIn() && (
        isAdmin() ||
        exists(/databases/$(database)/documents/enrollments/$(request.auth.uid + '_' + courseId))
      );
    }

    function getEnrolledIds() {
      return (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('enrolledCourseIds', []) 
        : [];
    }

    function isCourseOwner(courseId) {
      return isSignedIn() && exists(/databases/$(database)/documents/courses/$(courseId)) 
        && get(/databases/$(database)/documents/courses/$(courseId)).data.creatorId == request.auth.uid;
    }

    // Phase 4: Validation Blueprints
    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'name', 'code', 'creatorId', 'createdAt'])
        && data.keys().size() >= 5
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 256
        && data.code is string && data.code.size() <= 32
        && data.creatorId == request.auth.uid
        && data.createdAt is timestamp;
    }

    function isValidEnrollment(data, id) {
      return data.keys().hasAll(['id', 'studentId', 'courseId', 'enrolledAt', 'teacherId'])
        && data.keys().size() >= 5
        && data.id == id
        && data.id == data.studentId + '_' + data.courseId
        && data.studentId == request.auth.uid
        && data.enrolledAt is timestamp;
    }

    function isValidAttempt(data) {
      return data.keys().hasAll(['examId', 'studentId', 'courseId', 'teacherId', 'answers', 'score', 'attemptNumber', 'status'])
        && data.studentId == request.auth.uid
        && data.score is number
        && data.attemptNumber is number;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) 
        && data.uid is string 
        && data.email is string
        && data.role in ['student', 'teacher', 'admin'];
    }

    function isValidRoleAction(incoming, existing) {
      // Normal users can only request roles, not set them
      return (
        incoming.role == existing.role || isAdmin()
      ) && (
        // Users can update their request status OR their enrollment list OR profile fields
        incoming.diff(existing).affectedKeys().hasOnly(['roleRequest', 'updatedAt', 'enrolledCourseIds', 'onboardingCompleted', 'fullName']) ||
        isAdmin()
      );
    }

    function isValidQuestion(q) {
      return q.id is string && q.id.size() <= 128
        && q.type is string && q.type.size() <= 64
        && q.prompt is string && q.prompt.size() <= 5000
        && q.correctAnswer is string && q.correctAnswer.size() <= 2000
        && q.bloomLevel is string && q.bloomLevel.size() <= 64
        && q.difficulty in ['bajo', 'medio', 'alto'];
    }

    function isValidExam(data) {
      let coursePath = /databases/$(database)/documents/courses/$(data.courseId);
      return data.keys().hasAll(['id', 'title', 'topic', 'course', 'courseId', 'creatorId', 'createdAt'])
        && data.keys().size() >= 7
        && data.id is string && data.id.size() <= 128
        && data.courseId is string && data.courseId.size() <= 128
        && data.title is string && data.title.size() <= 512
        && data.topic is string && data.topic.size() <= 512
        && data.creatorId == request.auth.uid
        && data.createdAt is timestamp
        // Verify course exists and user owns it
        && exists(coursePath)
        && get(coursePath).data.creatorId == request.auth.uid
        // Array Guard: Max 50 questions
        && (!('questions' in data) || (data.questions is list && data.questions.size() <= 50));
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) 
        && incoming().uid == userId
        && isValidRoleAction(incoming(), existing());
      allow delete: if isAdmin();
    }

    // 2. Exams Collection
    match /exams/{examId} {
      allow get: if isSignedIn() && (
        isOwner(resource.data.creatorId) || 
        isAdmin() || 
        isTeacher() ||
        isEnrolled(resource.data.courseId)
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.creatorId == request.auth.uid ||
        isEnrolled(resource.data.courseId)
      );

      allow create: if isTeacher() && isValidId(examId) && isValidExam(incoming()) && (incoming().createdAt == request.time || incoming().createdAt is timestamp);
      
      allow update: if isSignedIn() && isValidId(examId) && isOwner(existing().get('creatorId', '')) && isValidExam(incoming())
        && incoming().creatorId == existing().get('creatorId', '')
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'topic', 'course', 'courseId', 'questions', 'semester', 'difficulty', 'teacherName', 'showTeacherInPdf', 'maxAttempts'])
        );

      allow delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid || isAdmin() || isTeacher());
    }

    // 2.1 Courses Collection
    match /courses/{courseId} {
      allow get, list: if isSignedIn();
      allow create: if isTeacher() && isValidCourse(incoming()) && incoming().id == courseId && (incoming().createdAt == request.time || incoming().createdAt is timestamp);
      allow update: if (resource.data.get('creatorId', '') == request.auth.uid || isAdmin()) && isValidCourse(incoming());
      allow delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid || isAdmin() || isTeacher());
    }

    // 2.2 Enrollments Collection
    match /enrollments/{enrollmentId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin() || isCourseOwner(resource.data.courseId));
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.studentId == request.auth.uid || 
        resource.data.get('teacherId', '') == request.auth.uid
      );
      allow create: if isSignedIn() && isValidEnrollment(incoming(), enrollmentId) && (incoming().enrolledAt == request.time || incoming().enrolledAt is timestamp);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.studentId == request.auth.uid) || (isSignedIn() && isCourseOwner(resource.data.courseId));
    }

    // 3. Submissions Collection
    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid && (incoming().submittedAt == request.time || incoming().submittedAt is timestamp);
      allow update, delete: if isAdmin();
    }

    // 4. Support Messages Collection
    match /support_messages/{messageId} {
      allow create: if true; // Allow anonymous or any user to send contact messages
      allow read, update, delete: if isAdmin();
    }

    // 5. ExamAttempts Collection
    match /exam_attempts/{attemptId} {
      allow get: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        isAdmin() || 
        resource.data.get('teacherId', '') == request.auth.uid
      );
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.studentId == request.auth.uid || 
        resource.data.get('teacherId', '') == request.auth.uid
      );
      allow create: if isSignedIn() && isValidAttempt(incoming());
      allow update: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
    }

    // 6. Conversations Collection
    match /conversations/{conversationId} {
      allow get: if isSignedIn() && (conversationId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      
      allow create: if isSignedIn() && (conversationId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (conversationId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && conversationId == request.auth.uid);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (conversationId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && (conversationId == request.auth.uid || isAdmin())
          && (incoming().senderId == request.auth.uid || isAdmin());
        allow update, delete: if isSignedIn() && (conversationId == request.auth.uid || isAdmin());
      }
    }

    // 7. Notifications Collection
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}

{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "roleRequest": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Question": {
      "title": "Exam Question",
      "description": "A single question item within an exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "prompt": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "justification": { "type": "string" },
        "competence": { "type": "string" },
        "learningOutcome": { "type": "string" },
        "bloomLevel": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["bajo", "medio", "alto"] },
        "difficultyJustification": { "type": "string" },
        "teacherRecommendation": { "type": "string" }
      },
      "required": ["id", "type", "prompt", "correctAnswer", "bloomLevel", "difficulty"]
    },
    "Exam": {
      "title": "Exam Instrument",
      "description": "An evaluation instrument generated by AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "course": { "type": "string" },
        "courseId": { "type": "string" },
        "semester": { "type": "string" },
        "difficulty": { "type": "string" },
        "questions": { "type": "array", "items": { "$ref": "Question" } },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "teacherName": { "type": "string" },
        "showTeacherInPdf": { "type": "boolean" }
      },
      "required": ["id", "title", "topic", "course", "courseId", "creatorId", "createdAt"]
    },
    "Course": {
      "title": "Academy Course",
      "description": "A course created by a teacher where students can enroll.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "code": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "code", "creatorId", "createdAt"]
    },
    "Enrollment": {
      "title": "Course Enrollment",
      "description": "Mapping between a student and a course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "courseId", "enrolledAt"]
    },
    "Submission": {
      "title": "Exam Attempt",
      "description": "Student result for a specific exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "studentId": { "type": "string" },
        "score": { "type": "number" },
        "answers": { "type": "object" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "examId", "studentId", "score", "submittedAt"]
    },
    "SupportMessage": {
      "title": "Support Message",
      "description": "Message sent from contact form to admin.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "userRole": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["unread", "read", "archived"] }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Conversation": {
      "title": "User Conversation",
      "description": "Conversation between user and admin.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "lastMessageAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Individual message in a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "conversationId", "senderId", "userId", "text", "createdAt"]
    },
    "ExamAttempt": {
      "title": "Exam Attempt",
      "description": "Attempt record for a student on an exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "examId": { "type": "string" },
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "answers": { "type": "object" },
        "score": { "type": "number" },
        "attemptNumber": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "finalized"] },
        "submittedAt": { "type": "string", "format": "date-time" },
        "percentageScore": { "type": "number" }
      },
      "required": ["id", "examId", "studentId", "attemptNumber", "status"]
    },
    "QuestionBankEntry": {
      "title": "Question Bank Entry",
      "description": "An institutional question stored in the bank.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "prompt": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "topic": { "type": "string" },
        "course": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["bajo", "medio", "alto", "integral"] },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "justification": { "type": "string" },
        "competence": { "type": "string" },
        "learningOutcome": { "type": "string" },
        "bloomLevel": { "type": "string" },
        "type": { "type": "string" },
        "inclusionGuidance": { "type": "string" }
      },
      "required": ["id", "prompt", "correctAnswer", "topic", "course", "difficulty", "creatorId", "createdAt", "status", "type"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles by UID."
    },
    "exams/{examId}": {
      "schema": "Exam",
      "description": "Generated exams."
    },
    "courses/{courseId}": {
      "schema": "Course",
      "description": "Academy courses."
    },
    "enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Student enrollments."
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Exam results."
    },
    "support_messages/{messageId}": {
      "schema": "SupportMessage",
      "description": "Messages for admin support."
    },
    "conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "List of user conversations."
    },
    "conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation."
    },
    "exam_attempts/{attemptId}": {
      "schema": "ExamAttempt",
      "description": "Student exam attempts."
    },
    "questionBank/{questionId}": {
      "schema": "QuestionBankEntry",
      "description": "Institutional question bank."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    }
  }
}
